    "merge:reports": "playwright merge-reports --reporter html ./all-blob-reports"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
