{
  "name": "ch11-ci-integration",
  "version": "0.1.0",
  "description": "Ch11 CI 統合 (Claude Code × Playwright MCP 実践ガイド)",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ci": "CI=true playwright test",
    "test:shard1": "CI=true playwright test --shard=1/2",
