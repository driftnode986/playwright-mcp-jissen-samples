{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "pages/**/*.ts",
    "tests/**/*.ts",
    "fixtures.ts",
    "playwright.config.ts",
    "seed.spec.ts"
  ]
}
